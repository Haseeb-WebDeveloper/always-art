# --- Sanity -----------------------------------------------------------------
# Public: safe to expose to the browser. Must match studio-alwaysart/.env
# (SANITY_STUDIO_PROJECT_ID / SANITY_STUDIO_DATASET).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01

# Server-only. Needed for draft preview / Visual Editing (Presentation).
# Create at https://sanity.io/manage -> API -> Tokens (Viewer role is enough).
# Optional for published-content reads on a public dataset.
SANITY_API_READ_TOKEN=
